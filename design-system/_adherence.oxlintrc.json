{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/book/**",
              "components/core/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Space Grotesk|Inter|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Space Grotesk, Inter, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|mono|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, mono, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|signal|outline)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'signal' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|disabled|onClick|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, disabled, onClick, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChapterKicker'] > JSXAttribute > JSXIdentifier[name!=/^(?:series|band|key|ref|className|style|children)$/]",
        "message": "<ChapterKicker> doesn't accept that prop. Declared props: series, band."
      },
      {
        "selector": "JSXOpeningElement[name.name='Divider'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|key|ref|className|style|children)$/]",
        "message": "<Divider> doesn't accept that prop. Declared props: label."
      },
      {
        "selector": "JSXOpeningElement[name.name='DualLayerBlock'] > JSXAttribute > JSXIdentifier[name!=/^(?:labelA|titleA|textA|labelB|titleB|textB|key|ref|className|style|children)$/]",
        "message": "<DualLayerBlock> doesn't accept that prop. Declared props: labelA, titleA, textA, labelB, titleB, textB."
      },
      {
        "selector": "JSXOpeningElement[name.name='GlassCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:strong|glow|children|key|ref|className|style|children)$/]",
        "message": "<GlassCard> doesn't accept that prop. Declared props: strong, glow, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='QRPanel'] > JSXAttribute > JSXIdentifier[name!=/^(?:url|size|key|ref|className|style|children)$/]",
        "message": "<QRPanel> doesn't accept that prop. Declared props: url, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='RadarMotif'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|pulse|key|ref|className|style|children)$/]",
        "message": "<RadarMotif> doesn't accept that prop. Declared props: size, pulse."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {
      "Badge": {
        "replaces": []
